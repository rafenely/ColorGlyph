@page "/"
@using ColorGlyphs
@using ColorGlyphs.Components
@using ColorGlyphs.Components.Shared
@using ColorGlyphs.Models
@using ColorGlyphs.Services
@using Microsoft.AspNetCore.Components.Web
@using System.Runtime.InteropServices
@rendermode InteractiveServer
@inject GlyphService GlyphService

<PageTitle>Traductor de Colores</PageTitle>

<h1>ColorGlyph</h1>

@*<input @bind="textoUsuario" @bind:event="oninput" placeholder="Escribe algo..." class="form-control" />*@
<div class="traductor-container">
    <label>Escribe tu mensaje:</label>
    @* Cambiamos input por textarea y vinculamos la variable *@
    <textarea class="form-control" 
              @bind="textoUsuario" 
              @bind:event="oninput" 
              rows="4" 
              placeholder="Escribe aquí...">
    </textarea>
</div>
<div class="d-flex justify-content-center mb-3">
    <div class="btn-group" role="group" aria-label="Alineación">
        <button type="button" class="btn btn-outline-secondary @(alineacion == "start" ? "active" : "")" 
                @onclick='() => CambiarAlineacion("start")'>
            <span class="bi bi-text-left"></span>
        </button>
        <button type="button" class="btn btn-outline-secondary @(alineacion == "center" ? "active" : "")" 
                @onclick='() => CambiarAlineacion("center")'>
            <span class="bi bi-text-center"></span>
        </button>
        <button type="button" class="btn btn-outline-secondary @(alineacion == "end" ? "active" : "")" 
                @onclick='() => CambiarAlineacion("end")'>
            <span class="bi bi-text-right"></span>
        </button>
        <button type="button" class="btn btn-outline-secondary @(alineacion == "between" ? "active" : "")" 
            @onclick='() => CambiarAlineacion("between")'>
            <span class="bi bi-justify"></span>
        </button>
    </div>
        <div class="d-flex align-items-center gap-3 mb-3 justify-content-center">
            <label class="form-label mb-0">Tamaño:</label>
            <input type="range" min="30" max="100" @bind="glyphSize" @bind:event="oninput" />
            <span>@(glyphSize)px</span>
        </div>
</div>
<div class="form-check form-switch mb-3">
    <input class="form-check-input" type="checkbox" id="checkMostrar" @bind="mostrarLetras" />
    <label class="form-check-label" for="checkMostrar">
        Mostrar etiquetas de letras
    </label>
</div>
<div class="hoja-libreta mt-4 d-flex flex-wrap justify-content-@alineacion">
    @foreach (var linea in textoUsuario.Split('\n'))
    {
        <div class="d-flex flex-wrap justify-content-@alineacion" style="flex-basis: 100%;">
            @* Luego separamos por espacios para identificar cada palabra *@
            @foreach (var palabra in linea.Split(' '))
            {
                <div class="grupo-palabra d-flex shadow-none">
                    @foreach (var cuadricula in GlyphService.TraducirTexto(palabra))
                    {
                        @if (cuadricula.Tipo == "Salto")
                        {
                            @* Esta línea fuerza a los siguientes glifos a ir a la fila de abajo *@
                            <div class="flex-break" style="flex-basis: 100%; height: @(glyphSize / 2)px;">
                            
                            </div>
                        }
                        else
                        {
                            <div class="cuadro-letra" style="width: @(glyphSize)px; height: @(glyphSize)px;">
                                <div class="marco-dibujo">
                                    <div class="rejilla-puntos">
                                        @{
                                            // Preparamos las listas de forma segura
                                            var colores = cuadricula.Colores.Split(',');
                                            var formas = cuadricula.GlyphForms;
                                            var formaBase = formas.FirstOrDefault()?.Form?.Description ?? "Cuadrada";
                                        }
                                        @for(int i= 0; i<colores.Length; i++)
                                        {

                                            var formaActual = (cuadricula.Tipo == "Especial" && i < formas.Count()) 
                                                                ? formas[i].Form.Description 
                                                                : formaBase;

                                            <div class="punto" 
                                                    style="@GetFormaStyle(formaActual)  background-color: @TraducirColor(colores[i]);">
                                            </div>                                      
                                        }
                                    </div>
                                </div>
                                @if(mostrarLetras)
                                {
                                    <span class="etiqueta-letra" style="font-size: @(glyphSize/4)px;">@cuadricula.Caracter</span>@**@
                                }
                            </div>
                        }
                    }
                </div>
                <div class="espacio-blanco" style="width: @(glyphSize+4)px;"></div>
            }
        </div>
        }
        
    
</div>
<style>
    /* El fondo de la zona donde aparecen las letras */
    .hoja-libreta {
        background-color: #ffffff;
        /*background-image: radial-gradient(#d1d1d1 1.5px, transparent 1.5px);
        background-size: 30px 30px; /* Tamaño de la cuadrícula de fondo */
        padding: 50px;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        box-shadow: inset 0 0 10px rgba(0,0,0,0.05), 0 5px 15px rgba(0,0,0,0.1);
        display: flex;
        flex-wrap: wrap;
        gap: 25px;
        min-height: 300px;
        align-content: flex-start;
        gap: 5px;
    }
    .cuadro-letra {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 2px;
        transition: all 0.2s ease;
    }
    .grupo-palabra {
            display: flex;
            flex-wrap: nowrap; /* IMPORTANTE: Las letras de una palabra NO se separan */
            /*gap: 10px;         /* Espacio entre letras de la misma palabra */
        }
    /* El marco individual de cada letra */
    .marco-dibujo {
        /*background: rgba(83, 52, 52, 0);
        border: 2px solid #444;
        padding: 0px;
        border-radius: 4px;*/
        /*  box-shadow: 3px 3px 0px #888; /* Efecto de relieve */
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .rejilla-puntos {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        align-content: space-around;
        height: 100%;
        width: 100%;
        padding: 2px;
    }

    .punto {
        width: 35%;
        height: 35%;
        margin: 2%;
        @*border-radius: 50%;
        border: 50% solid rgba(0, 0, 0, 0);*@
        filter: url(#ink-effect); 

        /* Toque final: Ligeramente translúcido para que se vea el papel detrás */
        opacity: 0.9;
        
        /* Pequeño desenfoque muy sutil para simular absorción */
        /*box-shadow: 0 0 2px rgba(0,0,0,0.2) inset;*/
    }
    .forma-circulo { border-radius: 50%; }
    .forma-cuadrado { border-radius: 2px; }

    .forma-triangulo {
        clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    }

    .forma-rombo {
        clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
    }

    .forma-estrella {
        clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    }
    .etiqueta-letra {
        display: block;
        text-align: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-weight: bold;
        color: #666;
        margin-top: 10px;
        font-size: 0.9rem;
        text-transform: uppercase;
    }
    .espacio-blanco {
    display: inline-block;
    flex-shrink: 0; /* Evita que el espacio se comprima si hay poco sitio */
    }
</style>
<svg width="0" height="0" style="position:absolute;z-index:-1;">
    <defs>
        <filter id="ink-effect">
            <feTurbulence type="fractalNoise" 
                          baseFrequency="0.04" 
                          numOctaves="3" 
                          result="noise" />
            
            <feDisplacementMap in="SourceGraphic" 
                               in2="noise" 
                               scale="5" 
                               xChannelSelector="R" 
                               yChannelSelector="G" />
            
            <feGaussianBlur stdDeviation="0.5" />
        </filter>
    </defs>
</svg>
@code {
    private string textoUsuario = "";
    private int cantidadEncontrada = 0;
    private bool mostrarLetras = false;
    private string alineacion = "start";
    private int glyphSize = 60;
    // Esta función se ejecutará cada vez que cambie el texto
    private void ActualizarTraduccion(ChangeEventArgs e)
    {
        textoUsuario = e.Value?.ToString() ?? "";
        var resultado = GlyphService.TraducirTexto(textoUsuario);
        cantidadEncontrada = resultado.Count;
    }

    private string TraducirColor(string forma)
    {
        var dbColor = GlyphService.GetColorCode(forma);
        return dbColor;
    }

    private string GetFormaStyle(string forma)
    {
        var dbForma = GlyphService.GetFormCode(forma);
        return dbForma;
    }

    private void CambiarAlineacion(string nuevaAlineacion)
    {
        alineacion = nuevaAlineacion;
    }
}