@page "/admin"
@using ColorGlyphs
@using ColorGlyphs.Models
@using ColorGlyphs.Components
@using ColorGlyphs.Components.Shared
@using ColorGlyphs.Services

@inject GlyphService GlyphService
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer
<h3 class="mb-4">Administración de Glyphos</h3>

<div class="card p-4 mb-5 shadow-sm">
    <h5>@(editandoId == 0 ? "Agregar Nuevo Glifo" : "Modificando Glifo")</h5>
    <div class="row g-3">
        <div class="col-md-2">
            <label class="form-label">Carácter/Símbolo</label>
            <input type="text" class="form-control" @bind="nuevoGlyph.Caracter" maxlength="1" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Formas (ej: circulo,triangulo)</label>
            <input type="text" class="form-control" @bind="formasTexto" placeholder="Circulo,Triangulo..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Colores (separados por coma)</label>
            <input type="text" class="form-control" @bind="nuevoGlyph.Colores" placeholder="Rojo,Azul..." />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary w-100" @onclick="Guardar">
                @(editandoId == 0 ? "Añadir" : "Actualizar")
            </button>
        </div>
        <div class="card p-3 mb-4 bg-light border-warning">
            <h6><span class="bi bi-exclamation-triangle-fill"></span> Acción Masiva: Cambiar todas las formas</h6>
            <div class="d-flex gap-2 align-items-center">
                <select class="form-select w-auto" @bind="formaMasivaSeleccionada">
                    <option value="">-- Selecciona una forma --</option>
                    @foreach (var f in todasLasFormas)
                    {
                        <option value="@f.Description">@f.Description</option>
                    }
                </select>
                <button class="btn btn-warning" @onclick="AplicarCambioMasivo">
                    Aplicar a todos los Glifos
                </button>
            </div>
        </div>
    </div>
</div>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Carácter</th>
            <th>Formas</th>
            <th>Colores</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var g in todosLosGlyphs.OrderBy(x => x.Caracter))
        {
            <tr>
                <td><strong>@g.Caracter</strong></td>
                <td>
                    @foreach (var gf in g.GlyphForms)
                    {
                        <span class="badge bg-secondary me-1">@gf.Form.Description</span>
                    }
                </td>
                <td><small>@g.Colores</small></td>
                <td>
                    <button class="btn btn-sm btn-outline-secondary me-2"
                            @onclick="() => CargarParaEditar(g)">Editar</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Borrar(g.Id)">Borrar</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<GlyphModel> todosLosGlyphs = new();
    private GlyphModel nuevoGlyph = new();
    private string formasTexto = ""; // Para manejar el input de texto
    private int editandoId = 0;

    private string formaMasivaSeleccionada = "";
    private List<FormModel> todasLasFormas = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarLista();
        todasLasFormas = await GlyphService.ObtenerFormas(); // Necesitarás este método en el service
    }

    private async Task CargarLista()
    {
        todosLosGlyphs = await GlyphService.ObtenerTodos();
    }

    private async Task Guardar()
    {
        if (string.IsNullOrEmpty(nuevoGlyph.Caracter)) return;

        nuevoGlyph.Tipo = GlyphService.GetGlyphType(nuevoGlyph);
        nuevoGlyph.GlyphForms = await GlyphService.ConvertirTextoAFormas(formasTexto);

        if (editandoId == 0) await GlyphService.Crear(nuevoGlyph);
        else await GlyphService.Actualizar(nuevoGlyph);

        nuevoGlyph = new();
        formasTexto = "";
        editandoId = 0;
        await CargarLista();
    }

    private void CargarParaEditar(GlyphModel g)
    {
        nuevoGlyph = new GlyphModel
        {
            Id = g.Id,
            Caracter = g.Caracter,
            Tipo = g.Tipo,
            GlyphForms = g.GlyphForms,
            Colores = g.Colores
        };
        
        if (g.GlyphForms != null && g.GlyphForms.Any())
        {
            formasTexto = string.Join(",", g.GlyphForms
                .Select(gf => gf.Form?.Description)
                .Where(d => d != null));
        }
        else
        {
            formasTexto = "";
        }
    
        editandoId = g.Id;
    }

    private async Task Borrar(int id)
    {
        await GlyphService.Eliminar(id);
        await CargarLista();
    }

    private async Task AplicarCambioMasivo()
    {
        if (string.IsNullOrEmpty(formaMasivaSeleccionada)) return;

        bool confirmar = await JSRuntime.InvokeAsync<bool>("confirm",
            new object[] { $"¿Seguro que quieres cambiar TODOS los glifos a {formaMasivaSeleccionada}?" });

        if (confirmar)
        {
            await GlyphService.CambiarTodasLasFormas(formaMasivaSeleccionada);
            await CargarLista();
            StateHasChanged();
        }
    }
}